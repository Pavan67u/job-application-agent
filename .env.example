# ── Google Gemini ──────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ── LinkedIn (use your login cookies or app credentials) ──
LINKEDIN_EMAIL=your_linkedin_email
LINKEDIN_PASSWORD=your_linkedin_password

# ── Naukri ─────────────────────────────────────────────
NAUKRI_EMAIL=your_naukri_email
NAUKRI_PASSWORD=your_naukri_password

# ── Job Search Config ──────────────────────────────────
JOB_TITLES=Software Engineer,Full Stack Developer,Data Analyst,ML Engineer,AI Engineer
JOB_LOCATION=Hyderabad
EXPERIENCE_YEARS=0
JOB_TYPE=entry level,fresher,0-2 years
MAX_JOBS_PER_RUN=20

# ── Resume ─────────────────────────────────────────────
BASE_RESUME_PATH=data/resumes/base_resume.docx

# ── Tracker ────────────────────────────────────────────
TRACKER_PATH=data/output/job_tracker.xlsx

# ── Scheduler ──────────────────────────────────────────
RUN_INTERVAL_HOURS=12
